{
  "enabled": true,
  "title": "ROASTED CHICKEN HEARTS",
  "lines": [
    "Chicken hearts: 700 g",
    "Salt: 2 tsp",
    "Oregano: 1 tbsp",
    "Olive oil: 1 tbsp, optional",
    "Oven: 200 C, preheated",
    "Pan: single layer, do not stack",
    "Turn at 15 min",
    "Turn again at 30 min",
    "Check at 40 min",
    "Done when dark inside, no pink center"
  ]
}
